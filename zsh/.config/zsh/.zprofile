# ~/.config/zsh/.zprofile

# =========================================================
# Login shell configuration
# =========================================================
#
# This file is read by login shells.
#
# Keep this file small. Most interactive shell behavior belongs in:
#
#   ~/.config/zsh/.zshrc
#
# Environment variables that should exist in every Zsh process belong in:
#
#   ~/.config/zsh/.zshenv
